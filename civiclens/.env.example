# ─────────────────────────────────────────────
#  CivicLens — Environment Variables
#  Copy to .env and fill in your values
# ─────────────────────────────────────────────

# Set to "true" for local dev (no Kafka/Redis needed)
LOCAL_MODE=true

# ── LLM Providers (all free tiers) ──────────
# 1. Groq — https://console.groq.com (primary, fastest)
GROQ_API_KEY=

# 2. Google Gemini — https://aistudio.google.com (secondary)
GEMINI_API_KEY=

# 3. HuggingFace — https://huggingface.co/settings/tokens (tertiary)
HF_API_TOKEN=

# ── Upstash Kafka (production mode only) ────
# https://console.upstash.com/kafka
UPSTASH_KAFKA_REST_URL=
UPSTASH_KAFKA_REST_USERNAME=
UPSTASH_KAFKA_REST_PASSWORD=

# ── Upstash Redis (cache) ────────────────────
# https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Supabase (production database) ──────────
# https://supabase.com/dashboard
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Set to "true" to use Supabase instead of local CSV
USE_SUPABASE=false
CSV_PATH=data/resources.csv
